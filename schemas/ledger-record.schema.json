{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pilotfish.dev/schemas/ledger-record.schema.json",
  "title": "Pilotfish Runtime Delegation Record v0.1",
  "type": "object",
  "required": [
    "record_id",
    "task_id",
    "sequence",
    "timestamp",
    "envelope_snapshot",
    "role_invoked",
    "model_claimed",
    "model_attested",
    "attestation_method",
    "attestation_status",
    "token_usage",
    "latency_ms",
    "execution_status",
    "verifier_verdict",
    "escalated_from",
    "supersedes_record_id"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "envelope_snapshot": {
      "$ref": "task-envelope.schema.json"
    },
    "role_invoked": {
      "enum": [
        "orchestrator",
        "scout",
        "Explore",
        "mech-executor",
        "executor",
        "senior-executor",
        "verifier",
        "security-executor"
      ]
    },
    "model_claimed": {
      "enum": [
        "best",
        "haiku",
        "sonnet",
        "opus"
      ]
    },
    "model_attested": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "attestation_method": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "attestation_status": {
      "enum": [
        "MATCHED",
        "MISMATCHED",
        "UNKNOWN",
        "NOT_APPLICABLE"
      ]
    },
    "token_usage": {
      "type": "object",
      "required": [
        "input",
        "output",
        "total"
      ],
      "properties": {
        "input": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "output": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "total": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "latency_ms": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "execution_status": {
      "enum": [
        "SUCCEEDED",
        "FAILED",
        "BLOCKED",
        "CANCELLED",
        "INVALIDATED"
      ]
    },
    "verifier_verdict": {
      "enum": [
        "CONFIRMED",
        "REFUTED",
        null
      ]
    },
    "escalated_from": {
      "enum": [
        "orchestrator",
        "scout",
        "Explore",
        "mech-executor",
        "executor",
        "senior-executor",
        "verifier",
        "security-executor",
        null
      ]
    },
    "supersedes_record_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "attestation_status": {
            "enum": [
              "MATCHED",
              "MISMATCHED"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "model_attested": {
            "type": "string",
            "minLength": 1
          },
          "attestation_method": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attestation_status": {
            "const": "MISMATCHED"
          }
        }
      },
      "then": {
        "properties": {
          "execution_status": {
            "const": "INVALIDATED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attestation_status": {
            "enum": [
              "UNKNOWN",
              "NOT_APPLICABLE"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "model_attested": {
            "type": "null"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
